    ],
    respuestaCliente: {
      texto: "Ok, vamos con el que incluye pasajeros 🙌",
      destino: "compra_plan_doble_medica"
    }
  },

  compra_plan_basico: {
    mensajes: ["<i>[Nodo pendiente: compra del plan básico $110 — datos del cliente y del auto, pago]</i>"],
    menu: { titulo: "¿Qué sigue?", opciones: [ { etiqueta: "⬅️ Menú principal", destino: "inicio" } ] }
  },

