  },

  terceros_orientar: {
    mensajes: ["<i>[Nodo pendiente: el bot explica qué cubre el seguro de terceros y recomienda un límite]</i>"],
    menu: { titulo: "¿Qué sigue?", opciones: [ { etiqueta: "⬅️ Menú principal", destino: "inicio" } ] }
  },

  cobertura_completa: {
    mensajes: [
      "🛡️ ¡Excelente! Vamos a cotizar un seguro con cobertura de <b>colisión y robo</b> para tu auto.<br><br><i>[Nodo pendiente: pasos de cotización]</i>"
    ],
    menu: { titulo: "¿Qué sigue?", opciones: [ { etiqueta: "⬅️ Menú principal", destino: "inicio" } ] }
  },

  agente: {
    mensajes: [
      "👤 Te estamos conectando con uno de nuestros agentes.<br><br>Horario de atención: <b>Lun–Vie, 8:00 a. m. – 5:00 p. m.</b><br><br>Un agente te responderá en breve. ⏳"
    ],
    fin: true
  }
};

/* ================= Motor del prototipo ================= */
const chat = document.getElementById("chat");
const rutaEl = document.getElementById("ruta");
let ruta = [];

function hora() {
  return new Date().toLocaleTimeString("es-PA", { hour: "numeric", minute: "2-digit", hour12: true }).toLowerCase();
}

function agregarBurbuja(html, tipo) {
  const b = document.createElement("div");
  b.className = "burbuja " + tipo;
  b.innerHTML = html + '<div class="hora">' + hora() + (tipo === "usuario" ? ' <span class="check">✓✓</span>' : "") + "</div>";
  chat.appendChild(b);
  bajarChat();
  setTimeout(bajarChat, 300);
}

function mostrarEscribiendo() {
  const e = document.createElement("div");
  e.className = "escribiendo";
  e.id = "escribiendo";
  e.innerHTML = "<i></i><i></i><i></i>";
  chat.appendChild(e);
  chat.scrollTop = chat.scrollHeight;
  document.getElementById("estado").textContent = "escribiendo...";
}

function quitarEscribiendo() {
  const e = document.getElementById("escribiendo");
  if (e) e.remove();
  document.getElementById("estado").textContent = "en línea";
}

function agregarMenu(menu) {
  const m = document.createElement("div");
  m.className = "menu";
  m.innerHTML = '<div class="menu-titulo">' + menu.titulo + "</div>";
  const botones = [];
  menu.opciones.forEach(op => {
    const o = document.createElement("div");
    o.className = "opcion";
    o.textContent = op.etiqueta;
    o.onclick = () => {
      m.querySelectorAll(".opcion").forEach(x => x.classList.add("desactivada"));
      elegir(op);
    };
    botones.push(o);
    m.appendChild(o);
  });
  chat.appendChild(m);
  bajarChat();
  setTimeout(bajarChat, 300);
  if (menu.autoElegir !== undefined) {
    setTimeout(() => botones[menu.autoElegir].click(), 2500);
  }
}

function bajarChat() {
  chat.scrollTop = chat.scrollHeight;
}

function irANodo(id) {
  const nodo = FLUJO[id];
  if (!nodo) return;
  ruta.push(id);
  rutaEl.textContent = ruta.join(" → ");

  let retraso = 0;
  nodo.mensajes.forEach((msg, i) => {
    setTimeout(() => {
      mostrarEscribiendo();
      setTimeout(() => {
        quitarEscribiendo();
        agregarBurbuja(msg, "bot");
        if (i === nodo.mensajes.length - 1) {
          if (nodo.menu) setTimeout(() => agregarMenu(nodo.menu), 600);
          if (nodo.respuestaCliente) {
            const rc = nodo.respuestaCliente;
            setTimeout(() => {
              agregarBurbuja(rc.texto, "usuario");
              setTimeout(() => irANodo(rc.destino), 900);
            }, 2200);
          }
        }
      }, 1300);
    }, retraso);
    retraso += 2200;
  });
}

function elegir(opcion) {
  agregarBurbuja(opcion.etiqueta, "usuario");
  setTimeout(() => irANodo(opcion.destino), 400);
}

function reiniciar() {
  chat.innerHTML =
    '<div class="chip">Hoy</div>' +
    '<div class="chip cifrado">🔒 Los mensajes están cifrados de extremo a extremo</div>';
  ruta = [];
  irANodo("inicio");
}

reiniciar();
</script>
</body>
</html>
