    ],
    respuestaCliente: {
      texto: "Puede ser... 🤔",
      destino: "terceros_tramite"
    }
  },

  terceros_tramite: {
    mensajes: [
      "El trámite es más rápido que lo que dura la luz verde. 🚦😄",
      "Solo me tienes que subir fotos de tu <b>licencia</b> 🪪, <b>cédula</b> y <b>registro de propiedad</b> del auto. Con eso ya tengo la información para hacer tu seguro.",
