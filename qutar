    ],
    menu: {
      titulo: "💳 Elige tu forma de pago",
      autoElegir: 0,
      opciones: [
        { etiqueta: "📱 Yappy — un solo pago ($165.00)",              destino: "pago_confirmado" },
        { etiqueta: "💳 Tarjeta de crédito — 3 pagos de $55.00",      destino: "pago_confirmado" }
      ]
    }
  },

  pago_confirmado: {
    mensajes: [
